# variables.tf

```terraform
variable "project_id" {
  type        = string
  description = "Service project ID"
}

variable "project_name" {
  type        = string
}

variable "billing_account" {
  type        = string
}

variable "folder_id" {
  type        = string
}

variable "host_project_id" {
  type        = string
}

variable "region" {
  type = string

  validation {
    condition     = can(regex("^([a-z]+-[a-z]+[0-9])$", var.region))
    error_message = "Invalid GCP region."
  }
}

variable "environment" {
  type = string

  validation {
    condition = contains(
      ["qa","preprod","prod"],
      var.environment
    )

    error_message = "Must be qa/preprod/prod."
  }
}

variable "labels" {
  type    = map(string)
  default = {}
}

variable "kms_key_id" {
  type = string
}

variable "gke_namespace" {
  type = string
}
```

