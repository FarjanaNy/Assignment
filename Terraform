# Cloud SQL Private Connectivity

Reserved range.

```terraform
resource "google_compute_global_address" "private_sql" {

  project = google_project.service_project.project_id

  name          = "private-sql-range"
  purpose       = "VPC_PEERING"
  address_type  = "INTERNAL"
  prefix_length = 16

  network = "projects/${var.host_project_id}/global/networks/shared-vpc"
}
```

```terraform
resource "google_service_networking_connection" "private_vpc" {

  network =
  "projects/${var.host_project_id}/global/networks/shared-vpc"

  service = "servicenetworking.googleapis.com"

  reserved_peering_ranges = [
    google_compute_global_address.private_sql.name
  ]
}
```

---

# Cloud SQL Instance

Private only.

```terraform
resource "google_sql_database_instance" "postgres" {

  name             = "${var.environment}-postgres"
  database_version = "POSTGRES_16"

  region = var.region

  deletion_protection = true

  settings {

    tier = "db-custom-2-8192"

    ip_configuration {

      ipv4_enabled = false

      private_network =
      "projects/${var.host_project_id}/global/networks/shared-vpc"
    }

    backup_configuration {
      enabled = true
    }
  }

  depends_on = [
    google_service_networking_connection.private_vpc
  ]
}
```

